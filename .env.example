# Public browser-safe values
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_VERCEL_ENV=development
# Set to true in deployed environments to require server-side Supabase Auth.
NEXT_PUBLIC_AXXESS_AUTH_SHELL=false
# Set to true for investor/customer demo environments with the seeded institution.
NEXT_PUBLIC_AXXESS_DEMO_MODE=false
NEXT_PUBLIC_AXXESS_APP_VERSION=0.8.0

# Supabase public client values. These are safe for browsers/mobile clients when RLS is enabled.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Analytics. Default to noop for clean tenants; select posthog or mixpanel explicitly.
NEXT_PUBLIC_ANALYTICS_PROVIDER=noop
NEXT_PUBLIC_ANALYTICS_DISABLED=false
NEXT_PUBLIC_ANALYTICS_DEBUG=false
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_MIXPANEL_TOKEN=
NEXT_PUBLIC_BETA_FEEDBACK_FORM_URL=

# Server-only values. Do not expose these through NEXT_PUBLIC_* variables.
# Required for invitation acceptance and user provisioning routes.
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PROJECT_REF=
SUPABASE_DB_URL=

# Auth/OAuth provider settings. Provider client secrets belong in Supabase or server-only hosting secrets.
NEXT_PUBLIC_AUTH_GOOGLE_ENABLED=false
NEXT_PUBLIC_AUTH_MICROSOFT_ENABLED=false
NEXT_PUBLIC_AUTH_APPLE_ENABLED=false
NEXT_PUBLIC_AUTH_PASSKEYS_ENABLED=false
NEXT_PUBLIC_AUTH_MFA_REQUIRED=false

# Server-only security integrations. Keep empty locally unless explicitly provisioned.
AXXESS_KMS_KEY_ALIAS=
AXXESS_SECRET_ROTATION_DAYS=90
AXXESS_AUDIT_HASH_SALT=
# Optional future provider keys. Sprint 11 RAG uses local deterministic retrieval by default.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GOOGLE_AI_API_KEY=
XAI_API_KEY=
FALCON_API_BASE_URL=
FALCON_API_KEY=
JAIS_API_BASE_URL=
JAIS_API_KEY=
LOCAL_AI_PROVIDER_ENABLED=true
AXXESS_AI_ROUTER_ENABLED=true
AXXESS_AI_DEFAULT_PROVIDER=local
AXXESS_AI_ROUTING_MODE=demo

# Productivity plugin registry. Keep OAuth secrets in provider secret stores.
GOOGLE_CLIENT_ID=
MICROSOFT_CLIENT_ID=
SLACK_CLIENT_ID=
WHATSAPP_BUSINESS_TOKEN=
NOTION_CLIENT_ID=
JIRA_CLIENT_ID=
TRELLO_API_KEY=
ASANA_CLIENT_ID=
LINEAR_CLIENT_ID=
GITHUB_APP_ID=
HUBSPOT_CLIENT_ID=
SALESFORCE_CLIENT_ID=
ZOHO_CLIENT_ID=
AIRTABLE_CLIENT_ID=
DOCUSIGN_INTEGRATION_KEY=
RAZORPAY_KEY_ID=

# Social alert ingestion. Provider credentials are optional and gated.
AXXESS_SOCIAL_ALERTS_ENABLED=false
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_PAGE_ACCESS_TOKEN=

# Sprint 7 seeded-branch E2E settings
E2E_RUN_SEEDED=false
E2E_AXXESS_PASSWORD=AxxessSprint7!
E2E_ORG_ADMIN_ALPHA=orgadmin.alpha@axxess.test
E2E_MANAGER_ALPHA=manager.alpha1@axxess.test
E2E_GUEST_ALPHA=guest.alpha@axxess.test
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000

# Mobile public values consumed by apps/mobile.
EXPO_PUBLIC_APP_URL=http://localhost:3000
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_EAS_PROJECT_ID=
EXPO_PUBLIC_IOS_BUNDLE_IDENTIFIER=com.triaxis.axxess
EXPO_PUBLIC_ANDROID_APPLICATION_ID=com.triaxis.axxess
EXPO_PUBLIC_ANALYTICS_PROVIDER=noop
EXPO_PUBLIC_POSTHOG_KEY=
EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
EXPO_PUBLIC_MIXPANEL_TOKEN=
EXPO_PUBLIC_AXXESS_DEMO_MODE=false

# Expo/EAS and Bitrise. Keep tokens and signing material in provider secret stores.
EXPO_TOKEN=
EAS_PROJECT_ID=
APPLE_ID=
ASC_APP_ID=
APPLE_TEAM_ID=
BITRISEIO_ANDROID_KEYSTORE_URL=
BITRISEIO_ANDROID_KEYSTORE_PASSWORD=
BITRISEIO_ANDROID_KEYSTORE_ALIAS=
BITRISEIO_ANDROID_KEYSTORE_PRIVATE_KEY_PASSWORD=
