# Public browser-safe values
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Set to true in deployed environments to require server-side Supabase Auth.
NEXT_PUBLIC_AXXESS_AUTH_SHELL=false
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only values. Do not expose these through NEXT_PUBLIC_* variables.
# Required for invitation acceptance and user provisioning routes.
SUPABASE_SERVICE_ROLE_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Sprint 7 seeded-branch E2E settings
E2E_RUN_SEEDED=false
E2E_AXXESS_PASSWORD=AxxessSprint7!
E2E_ORG_ADMIN_ALPHA=orgadmin.alpha@axxess.test
E2E_MANAGER_ALPHA=manager.alpha1@axxess.test
E2E_GUEST_ALPHA=guest.alpha@axxess.test
PLAYWRIGHT_BASE_URL=http://127.0.0.1:3000
