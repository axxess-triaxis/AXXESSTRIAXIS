{
    "name":  "@axxess/mobile-capacitor",
    "version":  "0.6.0-beta",
    "private":  true,
    "type":  "module",
    "scripts":  {
                    "prepare":  "node ../../scripts/prepare-mobile-certificates.mjs",
                    "sync":  "node ../../scripts/prepare-mobile-certificates.mjs \u0026\u0026 node ../../scripts/sync-repo-state.mjs \u0026\u0026 node ../../scripts/validate-mobile-env.mjs \u0026\u0026 npx cap sync",
                    "copy":  "npx cap copy",
                    "android":  "npx cap open android",
                    "ios":  "npx cap open ios",
                    "doctor":  "npx cap doctor",
                    "build:android":  "npm run prepare \u0026\u0026 node ../../scripts/sync-repo-state.mjs \u0026\u0026 node ../../scripts/validate-mobile-env.mjs \u0026\u0026 npx cap sync android \u0026\u0026 npx cap build android",
                    "build:ios":  "npm run prepare \u0026\u0026 node ../../scripts/sync-repo-state.mjs \u0026\u0026 node ../../scripts/validate-mobile-env.mjs \u0026\u0026 npx cap sync ios \u0026\u0026 npx cap build ios",
                    "build:all":  "npm run build:android \u0026\u0026 npm run build:ios"
                },
    "dependencies":  {
                         "@capacitor/android":  "^7.0.0",
                         "@capacitor/app":  "^7.0.0",
                         "@capacitor/browser":  "^7.0.0",
                         "@capacitor/camera":  "^7.0.0",
                         "@capacitor/core":  "^7.0.0",
                         "@capacitor/device":  "^7.0.0",
                         "@capacitor/filesystem":  "^7.0.0",
                         "@capacitor/haptics":  "^7.0.0",
                         "@capacitor/keyboard":  "^7.0.0",
                         "@capacitor/network":  "^7.0.0",
                         "@capacitor/preferences":  "^7.0.0",
                         "@capacitor/share":  "^7.0.0",
                         "@capacitor/splash-screen":  "^7.0.0",
                         "@capacitor/status-bar":  "^7.0.0"
                     },
    "devDependencies":  {
                            "@capacitor/cli":  "^7.0.0"
                        }
}
