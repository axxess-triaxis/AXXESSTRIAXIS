{
  "name": "@axxess/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "android:preview": "eas build --platform android --profile preview --non-interactive",
    "android:ci:build": "expo prebuild --platform android --clean --no-install && cd android && ./gradlew assembleDebug",
    "android:firebase:distribute": "npx firebase-tools@latest appdistribution:distribute android/app/build/outputs/apk/debug/app-debug.apk --app \"$FIREBASE_APP_ID_ANDROID\" --groups \"$FIREBASE_TESTER_GROUPS\"",
    "eas:build:configure": "eas build:configure --platform all",
    "eas:build:all": "eas build --profile preview --non-interactive",
    "eas:build:android": "eas build --platform android --profile preview --non-interactive",
    "eas:build:ios": "eas build --platform ios --profile preview --non-interactive",
    "eas:build:production:all": "npx eas-cli@latest build --platform all --profile production",
    "eas:credentials": "eas credentials",
    "eas:credentials:android": "eas credentials --platform android",
    "eas:credentials:ios": "eas credentials --platform ios",
    "eas:workflow:production": "npx eas-cli@latest workflow:run create-production-builds.yml",
    "ios:preview": "eas build --platform ios --profile preview --non-interactive",
    "lint": "expo lint",
    "mobile:free:android": "pnpm run android:ci:build && pnpm run android:firebase:distribute",
    "start": "expo start",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "^54.0.0",
    "expo-linking": "^8.0.0",
    "expo-router": "^6.0.0",
    "expo-secure-store": "^15.0.0",
    "expo-status-bar": "^3.0.0",
    "react": "^19.1.0",
    "react-native": "^0.81.0",
    "react-native-safe-area-context": "^5.6.0",
    "react-native-screens": "^4.16.0"
  },
  "devDependencies": {
    "@types/react": "^19.1.0",
    "typescript": "^5.8.3"
  }
}
