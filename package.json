{
  "name": "axxess-enterprise-saas",
  "private": true,
  "description": "AI-enabled human-in-the-loop institutional intelligence platform for enterprise, government, healthcare, NGO, and consulting organizations.",
  "version": "0.6.0-beta",
  "license": "Apache-2.0",
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=11.0.0"
  },
  "scripts": {
    "build": "next build",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run test && pnpm run build",
    "dev": "next dev",
    "lint": "eslint . --max-warnings=0",
    "mobile:android:preview": "pnpm --dir apps/mobile run android:preview",
    "mobile:capacitor:install": "pnpm --dir apps/mobile-capacitor install",
    "mobile:capacitor:prepare": "node scripts/prepare-mobile-certificates.mjs && node scripts/sync-repo-state.mjs",
    "mobile:capacitor:sync": "node scripts/prepare-mobile-certificates.mjs && node scripts/sync-repo-state.mjs && node scripts/validate-mobile-env.mjs && pnpm --dir apps/mobile-capacitor run sync",
    "mobile:capacitor:copy": "pnpm --dir apps/mobile-capacitor run copy",
    "mobile:capacitor:android": "pnpm --dir apps/mobile-capacitor run android",
    "mobile:capacitor:ios": "pnpm --dir apps/mobile-capacitor run ios",
    "mobile:capacitor:build:android": "node scripts/mobile-version.mjs && pnpm --dir apps/mobile-capacitor run build:android",
    "mobile:capacitor:build:ios": "node scripts/mobile-version.mjs && pnpm --dir apps/mobile-capacitor run build:ios",
    "mobile:capacitor:build:all": "node scripts/mobile-version.mjs && pnpm --dir apps/mobile-capacitor run build:all",
    "mobile:capacitor:doctor": "pnpm --dir apps/mobile-capacitor run doctor",
    "mobile:capacitor:version": "node scripts/mobile-version.mjs",
    "mobile:capacitor:release:android": "pnpm run mobile:capacitor:build:android",
    "mobile:capacitor:release:ios": "pnpm run mobile:capacitor:build:ios",
    "mobile:dev": "pnpm --dir apps/mobile run start",
    "mobile:eas:build:all": "pnpm --dir apps/mobile run eas:build:all",
    "mobile:eas:build:android": "pnpm --dir apps/mobile run eas:build:android",
    "mobile:eas:build:ios": "pnpm --dir apps/mobile run eas:build:ios",
    "mobile:eas:build:production:all": "pnpm --dir apps/mobile run eas:build:production:all",
    "mobile:eas:configure": "pnpm --dir apps/mobile run eas:build:configure",
    "mobile:eas:credentials": "pnpm --dir apps/mobile run eas:credentials",
    "mobile:eas:credentials:android": "pnpm --dir apps/mobile run eas:credentials:android",
    "mobile:eas:credentials:ios": "pnpm --dir apps/mobile run eas:credentials:ios",
    "mobile:eas:workflow:production": "pnpm --dir apps/mobile run eas:workflow:production",
    "mobile:ios:preview": "pnpm --dir apps/mobile run ios:preview",
    "mobile:typecheck": "pnpm --dir apps/mobile run typecheck",
    "export:wix": "node scripts/export-wix.mjs",
    "release:preflight": "node scripts/release-preflight.mjs",
    "release:ready": "pnpm run ci && pnpm run release:preflight -- --mode=ci && pnpm run mobile:capacitor:doctor",
    "start": "next start",
    "test": "vitest run --config vitest.config.mjs",
    "test:e2e": "playwright test",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@mui/icons-material": "7.3.5",
    "@mui/material": "9.1.2",
    "@popperjs/core": "2.11.8",
    "@radix-ui/react-accordion": "1.2.3",
    "@radix-ui/react-alert-dialog": "1.1.6",
    "@radix-ui/react-aspect-ratio": "1.1.11",
    "@radix-ui/react-avatar": "1.1.3",
    "@radix-ui/react-checkbox": "1.1.4",
    "@radix-ui/react-collapsible": "1.1.3",
    "@radix-ui/react-context-menu": "2.2.6",
    "@radix-ui/react-dialog": "1.1.6",
    "@radix-ui/react-dropdown-menu": "2.1.6",
    "@radix-ui/react-hover-card": "1.1.6",
    "@radix-ui/react-label": "2.1.11",
    "@radix-ui/react-menubar": "1.1.6",
    "@radix-ui/react-navigation-menu": "1.2.5",
    "@radix-ui/react-popover": "1.1.6",
    "@radix-ui/react-progress": "1.1.2",
    "@radix-ui/react-radio-group": "1.2.3",
    "@radix-ui/react-scroll-area": "1.2.3",
    "@radix-ui/react-select": "2.1.6",
    "@radix-ui/react-separator": "1.1.11",
    "@radix-ui/react-slider": "1.2.3",
    "@radix-ui/react-slot": "1.3.0",
    "@radix-ui/react-switch": "1.1.3",
    "@radix-ui/react-tabs": "1.1.3",
    "@radix-ui/react-toggle": "1.1.2",
    "@radix-ui/react-toggle-group": "1.1.2",
    "@radix-ui/react-tooltip": "1.1.8",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "canvas-confetti": "1.9.4",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "4.4.0",
    "embla-carousel-react": "8.6.0",
    "input-otp": "1.4.2",
    "lucide-react": "0.487.0",
    "mixpanel-browser": "2.80.0",
    "motion": "12.42.2",
    "next": "^15.0.0",
    "next-themes": "0.4.6",
    "react": "19.2.7",
    "react-day-picker": "10.0.1",
    "react-dnd": "16.0.1",
    "react-dnd-html5-backend": "16.0.1",
    "react-dom": "19.2.7",
    "react-hook-form": "7.55.0",
    "react-popper": "2.3.0",
    "react-resizable-panels": "2.1.7",
    "react-responsive-masonry": "2.7.2",
    "react-router": "7.13.0",
    "react-slick": "0.31.0",
    "recharts": "3.9.2",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "vaul": "1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.51.1",
    "@rollup/rollup-win32-x64-msvc": "4.62.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@tailwindcss/vite": "4.1.12",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.16.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "eslint": "^9.19.0",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "4.1.12",
    "typescript": "^6.0.3",
    "vite": "6.3.5",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  }
}
